{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's/\"version\": \".*\"/\"version\": \"${nextRelease.version}\"/' book-front/package.json && sed -i '/semantic-release/s#<version>.*</version>#<version>${nextRelease.version}</version>#' book-back/pom.xml"
      }
    ],
    "@semantic-release/changelog",
    "@semantic-release/github",
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "book-front/package.json",
          "book-back/pom.xml"
        ],
        "message": "chore(release): ${nextRelease.version}"
      }
    ]
  ]
}